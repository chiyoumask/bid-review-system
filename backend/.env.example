# 招投标文件智能审核系统 - 环境变量配置
# 复制此文件为 .env 并修改配置

# ===== 应用配置 =====
SECRET_KEY=change-me-to-a-random-string-in-production
DEBUG=true

# ===== 数据库 =====
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bid_review

# ===== LLM API 配置 =====
# DeepSeek
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TIMEOUT=120

# ===== CORS =====
# 允许的前端地址，逗号分隔
CORS_ORIGINS=["http://localhost:5173","http://localhost:8080"]

# ===== 文件上传 =====
MAX_FILE_SIZE_MB=50
