# =================================================================
# 招投标文件智能审核系统 - 环境变量配置
# 复制此文件为 .env 并修改
# =================================================================

# ===== 安全 =====
# 生产环境必须修改！使用随机字符串: openssl rand -hex 32
SECRET_KEY=please-change-me-to-random-string

# ===== 数据库 =====
DB_PASSWORD=please-change-me-to-strong-password
# Docker Compose 会自动覆盖为 db 容器地址；本地开发可按实际数据库修改
DATABASE_URL=postgresql+asyncpg://bid_review:please-change-me-to-strong-password@localhost:5432/bid_review

# ===== LLM API =====
# DeepSeek: https://api.deepseek.com/v1 / deepseek-chat
# 通义千问: https://dashscope.aliyuncs.com/compatible-mode/v1 / qwen-plus
# OpenAI: https://api.openai.com/v1 / gpt-4o
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TIMEOUT=120

# ===== CORS =====
# 填入你的域名或 IP，用于跨域访问
CORS_ORIGINS=["http://your-server-ip","http://your-domain.com"]

# ===== Docker 前端端口 =====
# 宝塔面板部署推荐保持 127.0.0.1:8080，再在宝塔站点中反向代理到该地址
FRONTEND_BIND=127.0.0.1
FRONTEND_HTTP_PORT=8080

# ===== 文件上传 =====
MAX_FILE_SIZE_MB=50
