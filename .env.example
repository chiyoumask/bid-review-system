# =================================================================
# 招投标文件智能审核系统 - Docker Compose 环境变量模板
# 复制为 .env 后修改密钥、数据库密码和 LLM 配置
# =================================================================

# ===== 安全 =====
# 生产环境必须修改，建议使用: openssl rand -hex 32
SECRET_KEY=please-change-me-to-random-string

# ===== 数据库 =====
DB_PASSWORD=please-change-me-to-strong-password
# Docker Compose 内部使用服务名 db；本地非 Docker 开发时可改为 localhost
DATABASE_URL=postgresql+asyncpg://bid_review:please-change-me-to-strong-password@db:5432/bid_review

# ===== LLM API =====
# DeepSeek: https://api.deepseek.com/v1 / deepseek-chat
# 通义千问: https://dashscope.aliyuncs.com/compatible-mode/v1 / qwen-plus
# OpenAI: https://api.openai.com/v1 / gpt-4o
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TIMEOUT=120

# ===== CORS =====
# 必须是 JSON 数组格式；使用宝塔域名访问时请填入实际域名
CORS_ORIGINS=["http://your-server-ip","http://your-domain.com","https://your-domain.com"]

# ===== Docker 前端端口 =====
# 如果直接用 Docker 暴露公网端口，可设 FRONTEND_BIND=0.0.0.0。
# 宝塔面板部署推荐保持 127.0.0.1:8080，再在宝塔站点中反向代理到该地址。
FRONTEND_BIND=127.0.0.1
FRONTEND_HTTP_PORT=8080

# ===== 文件上传 =====
MAX_FILE_SIZE_MB=50
